theme = argonaut
font-family = CommitMono Nerd Font
font-feature = ss03
font-feature = ss04
font-feature = ss05
adjust-cell-height = 10%

cursor-color = #ffffff
cursor-style = bar
adjust-cursor-thickness = 2
selection-background = #3d89ed
selection-foreground = #ffffff

window-width = 120
window-height = 35
window-padding-x = 8,2

window-save-state = never
confirm-close-surface = false

# Does not respect '$' and other signs
macos-option-as-alt = false
# SSH env did not work, might be fixed in Ghostty 1.3.2
shell-integration-features = true
shell-integration-features = no-ssh-env

# Quick Terminal
quick-terminal-position = right
keybind = global:alt+§=toggle_quick_terminal

# MacOS like movements
keybind = cmd+backspace=text:\x15
keybind = cmd+shift+backspace=csi:99~
keybind = cmd+left=csi:1;9D
keybind = cmd+right=csi:1;9C
keybind = alt+left=csi:1;3D
keybind = alt+right=csi:1;3C

keybind = cmd+enter=new_split:auto
keybind = cmd+alt+left=previous_tab
keybind = cmd+alt+right=next_tab
